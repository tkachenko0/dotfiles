#!/usr/bin/env bash
set -uo pipefail

MAX_DEPTH=2
TARGET_DIR=$(realpath "${1:-.}")

output=""

while IFS= read -r gitdir; do
    repo_dir="$(dirname "$gitdir")"
    [[ -d "$repo_dir" ]] || continue
    repo_name=$(basename "$repo_dir")

    line=$(
        cd "$repo_dir" 2>/dev/null || exit 0

        branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "???")

        dirty=""
        [[ -n $(git status --porcelain 2>/dev/null) ]] && dirty="*"

        ahead_behind=""
        upstream=$(git rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || true)
        if [[ -n "$upstream" ]]; then
            ahead=$(git rev-list --count '@{upstream}..HEAD' 2>/dev/null || echo 0)
            behind=$(git rev-list --count 'HEAD..@{upstream}' 2>/dev/null || echo 0)
            [[ "$ahead" -gt 0 ]] && ahead_behind+="+${ahead}"
            [[ "$behind" -gt 0 ]] && ahead_behind+="-${behind}"
        fi

        last_commit=$(git log -1 --format='%cr' 2>/dev/null || echo "no commits")

        echo "${repo_name}|${branch}|${dirty}|${ahead_behind}|${last_commit}"
    )

    [[ -n "$line" ]] && output+="${line}"$'\n'

done < <(find "$TARGET_DIR" -maxdepth "$MAX_DEPTH" -type d -name ".git" | sort)

if [[ -n "$output" ]]; then
    echo "$output" | column -t -s '|'
fi
